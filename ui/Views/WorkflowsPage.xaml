<Page
    x:Class="WinForgeShell.Views.WorkflowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinForgeShell.ViewModels"
    xmlns:svc="using:WinForgeShell.Services"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="12,8">

            <TextBlock
                Text="Workflows"
                Style="{ThemeResource TitleTextBlockStyle}"
                VerticalAlignment="Center"/>

            <Button
                Content="Refresh"
                Command="{x:Bind ViewModel.LoadWorkflowsCommand}"
                VerticalAlignment="Center">
                <Button.Icon>
                    <FontIcon Glyph="&#xE72C;"/>
                </Button.Icon>
            </Button>

            <Button
                Content="Run"
                Command="{x:Bind ViewModel.RunWorkflowCommand}"
                VerticalAlignment="Center"
                Style="{ThemeResource AccentButtonStyle}">
                <Button.Icon>
                    <FontIcon Glyph="&#xE768;"/>
                </Button.Icon>
            </Button>
        </StackPanel>

        <!-- Two-panel layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: workflow list -->
            <Grid Grid.Column="0" BorderThickness="0,0,1,0"
                  BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Available Workflows"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Margin="12,8,12,4"/>

                <!-- Empty state shown when list is empty -->
                <TextBlock
                    Grid.Row="1"
                    x:Name="WorkflowEmptyState"
                    Text="No workflows found.&#x0a;Press Refresh to load."
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    Margin="16"
                    Visibility="Visible"/>

                <ListView
                    Grid.Row="1"
                    x:Name="WorkflowListView"
                    ItemsSource="{x:Bind ViewModel.Workflows, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedWorkflow, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="svc:WorkflowItem">
                            <StackPanel Padding="4,6" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock
                                    Text="{x:Bind DisplayLabel}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Right panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Padding="12,8" Spacing="4">
                    <TextBlock
                        Text="Event Log"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBlock
                        Text="Live push events and workflow activity appear below (newest first)."
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Event log -->
                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    Padding="8">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.EventLog, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock
                                    Text="{x:Bind}"
                                    FontFamily="Consolas, Courier New, monospace"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
