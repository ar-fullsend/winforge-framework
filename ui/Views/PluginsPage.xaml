<Page
    x:Class="WinForgeShell.Views.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinForgeShell.ViewModels"
    xmlns:svc="using:WinForgeShell.Services"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="12,8">

            <TextBlock
                Text="Plugins"
                Style="{ThemeResource TitleTextBlockStyle}"
                VerticalAlignment="Center"/>

            <Button
                Content="Refresh"
                Command="{x:Bind ViewModel.LoadPluginsCommand}"
                VerticalAlignment="Center">
                <Button.Icon>
                    <FontIcon Glyph="&#xE72C;"/>
                </Button.Icon>
            </Button>
        </StackPanel>

        <!-- Plugin list with column headers -->
        <Grid Grid.Row="1" Margin="12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Grid Grid.Row="0" Padding="12,6" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="Version"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="Description"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="Capabilities"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontWeight="SemiBold"/>
            </Grid>

            <!-- Plugin rows -->
            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Plugins, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="svc:PluginItem">
                        <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind Name}"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Version}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind Description}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind Description}"/>
                            <TextBlock
                                Grid.Column="3"
                                Text="{x:Bind Capabilities}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind Capabilities}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <Grid
                Grid.Row="1"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
                <TextBlock
                    Text="No plugins loaded. Press Refresh to query the backend."
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    Margin="32"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
